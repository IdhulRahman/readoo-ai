# =========================================================================
# REAADO SYSTEM ENVIRONMENT CONFIGURATION (GENERAL PURPOSE AI PLATFORM)
# =========================================================================

# 1. FRONTEND SERVER SETTINGS
PORT=3000
PYTHON_HOST=127.0.0.1
PYTHON_PORT=5000

# 2. CORE SECURITY SETTINGS
# Encrypts LLM API keys in the SQLite database. Generate using:
# Python -> from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
ENCRYPTION_KEY=TrGBorFNd00aBjsMIfu6IK31Kyfi8blz9Q_HHaHivu8=

# 3. LLM CONFIGURATIONS
# Supported providers: groq | openai | gemini | deepseek | ollama
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# Optional Local Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# 4. RETRIEVAL AUGMENTED GENERATION (RAG)
# Embedding model name for semantic vector searches
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Central reranker (Optional - requires GPU or high-speed CPU)
USE_RERANKER=false
RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual
RERANK_THRESHOLD=0.45

# 5. VOICE & AUDIO CONFIGURATIONS
# TTS Provider: edge-tts (online) | supertonic (local ONNX)
TTS_PROVIDER=edge-tts
TTS_VOICE=id-ID-GadisNeural
TTS_RATE=+0%
SUPERTONIC_VOICE=W1

# STT (Whisper options: tiny | base | small | medium | large)
WHISPER_MODEL=base
# Optional: Use Groq Cloud STT for faster translation
# GROQ_STT_API_KEY=your_groq_api_key_here
